{
  "frida": {
    "default_device": "emulator-5554",
    "default_package": "com.example.app",
    "timeout_seconds": 30,
    "spawn_delay_seconds": 2
  },
  "hooks": {
    "native": {
      "default_library": "libnative-lib.so",
      "max_hooks": 1000,
      "log_arguments": true,
      "log_return_value": true
    },
    "java": {
      "default_class": "com.example.MainActivity",
      "default_methods": ["onCreate", "onResume", "onPause"],
      "log_arguments": true,
      "log_return_value": true
    }
  },
  "memory": {
    "scan": {
      "max_results": 1000,
      "default_pattern": "48 65 6c 6c 6f",
      "memory_regions": ["r--", "rw-", "rwx"]
    },
    "read": {
      "max_size": 10485760,
      "default_size": 1024
    },
    "write": {
      "max_size": 1048576,
      "default_data": "90 90 90 90"
    }
  },
  "logging": {
    "level": "info",
    "include_timestamp": true,
    "include_stack_trace": false
  },
  "output": {
    "save_to_file": false,
    "output_directory": "/tmp/frida_output",
    "max_log_size_mb": 100
  }
}
